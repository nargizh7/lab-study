{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/benweinshel/task-manager/.claude/hooks/on_user_prompt.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/benweinshel/task-manager/.claude/hooks/on_pre_edit.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/benweinshel/task-manager/.claude/hooks/on_pre_bash.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/benweinshel/task-manager/.claude/hooks/on_pre_read.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash|Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/benweinshel/task-manager/.claude/hooks/on_post_tool.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/benweinshel/task-manager/.claude/hooks/on_stop.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
